{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Hardware Test",
            "type": "debugpy",
            "request": "launch",
            "module": "pytest",
            "args": [
                "functional_tests/test_unified_bcm.py::test_ebd_split",
                "--target=hardware",
                "-s",
                "-v"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Debug BCM Firmware (ST-Link)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "stutil",
            "cwd": "${workspaceFolder}",
            "executable": "firmware/BCM_Firmware/build/BCM_Firmware.elf",
            "device": "STM32F401RE",
            "interface": "swd",
            "runToEntryPoint": "main",
            "preLaunchTask": "Build Firmware"
        }
    ]
}
