{
    "configurations": [
        {
            "name": "Mac-STM32",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/bcm/include",
                "${workspaceFolder}/bcm/src",
                "${workspaceFolder}/firmware/src"
            ],
            "defines": [
                "STM32F401xE",
                "USE_HAL_DRIVER"
            ],
            "compilerPath": "/opt/homebrew/bin/arm-none-eabi-gcc",
            "cStandard": "c11",
            "cppStandard": "c++17",
            "intelliSenseMode": "macos-gcc-arm"
        }
    ],
    "version": 4
}
